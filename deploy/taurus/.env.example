FASTMCP_TRANSPORT=http
FASTMCP_HOST=0.0.0.0
FASTMCP_PORT=34128
LOG_LEVEL=ERROR

MCP_AUTH_TOKEN=replace-with-a-long-random-token
MCP_AUTH_HEADER=Authorization

IMAGE_PROVIDER=openai
OPENAI_API_KEY=replace-with-openai-compatible-key
OPENAI_BASE_URL=https://toapis.com/v1
OPENAI_MODEL=gpt-image-2
OPENAI_MAX_POLL_SECONDS=180
OPENAI_POLL_INTERVAL=3

GEMINI_API_KEY=your-gemini-key
GEMINI_API_BASE_URL=https://your-gemini-compatible-endpoint.example.com/v1

JIMENG_ACCESS_KEY=your-volcengine-access-key
JIMENG_SECRET_KEY=your-volcengine-secret-key

LAS_API_KEY=your-las-image-api-key
ARK_API_KEY=your-legacy-ark-key
JIMENG45_API_KEY=your-las-image-api-key

MAX_CONCURRENT_REQUESTS=8
OPENAI_MAX_CONCURRENT_REQUESTS=2
GEMINI_MAX_CONCURRENT_REQUESTS=2
QUEUE_WAIT_TIMEOUT_SECONDS=600

IMAGE_OUTPUT_DIR=/data/output

MINIO_ENDPOINT=127.0.0.1:34124
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_BUCKET=image-this
MINIO_SECURE=false
MINIO_PUBLIC_BASE_URL=http://38.76.197.25:34124
MINIO_KEY_PREFIX=image-this
MINIO_PRESIGN_EXPIRY_SECONDS=86400
